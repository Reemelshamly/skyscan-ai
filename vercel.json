{
  "version": 2,
  "buildCommand": "npm run build",
  "env": {
    "VITE_PREDICT_API_URL": "https://reem223-skyscan-ai-backend.hf.space"
  },
  "functions": {
    "api/ssr.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/dist/client/assets/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/api/ssr.js"
    }
  ]
}
