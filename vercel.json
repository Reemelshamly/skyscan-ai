{
  "version": 2,
  "buildCommand": "npm run build",
  "env": {
    "VITE_PREDICT_API_URL": "https://reem223-skyscan-ai-backend.hf.space"
  },
  "builds": [
    { "src": "dist/server/index.js", "use": "@vercel/node" },
    { "src": "dist/client/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/dist/client/assets/$1" },
    { "src": "/(.*)", "dest": "/api/ssr.js" }
  ]
}
